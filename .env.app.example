COMPOSE_PROJECT_NAME=lgtm-app-stack
COMPOSE_FILE=docker-compose.app.yml

# Monitoring VM private IP used by Promtail and the MSA service OTLP exporters.
MONITORING_VM_PRIVATE_IP=10.0.0.10
APP_HOST_LABEL=app-vm

# Synthetic business failure probabilities for the demo app.
# Keep these low for long-running observation; raise them only for error-rate demonstrations.
INVENTORY_LOW_STOCK_CHANCE=0.01
PAYMENT_DECLINE_CHANCE=0.02

# Keep Promtail and Loki on the same release line.
PROMTAIL_VERSION=3.6.11
NODE_EXPORTER_VERSION=v1.11.1
