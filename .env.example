COMPOSE_PROJECT_NAME=lgtm-monitoring-stack

# Version policy:
# - Avoid floating "latest" tags for reproducible reports and demos.
# - Prefer current stable patch releases, but avoid brand-new major lines.
# - App VM telemetry collection is handled by Grafana Alloy in K3S.
GRAFANA_VERSION=12.4.3
LOKI_VERSION=3.6.11
MIMIR_VERSION=3.1.2
TEMPO_VERSION=2.10.7
PROMETHEUS_VERSION=v3.5.4
ALERTMANAGER_VERSION=v0.28.1
NODE_EXPORTER_VERSION=v1.11.1
MINIO_VERSION=RELEASE.2025-09-07T16-13-09Z
MINIO_MC_VERSION=RELEASE.2025-08-13T08-35-41Z
OTEL_COLLECTOR_VERSION=0.155.0
CURL_VERSION=8.16.0

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

MINIO_ROOT_USER=lgtm
MINIO_ROOT_PASSWORD=lgtm-secret-key

# Retention policy:
# - Loki has stream-level retention in configs/loki/loki-config.yaml.
# - Prometheus local TSDB, Mimir, and Tempo are controlled globally here.
PROMETHEUS_LOCAL_RETENTION=168h
MIMIR_METRICS_RETENTION=168h
TEMPO_TRACE_RETENTION=168h

# Slack Incoming Webhook URL used by Alertmanager.
# Do not commit a real webhook URL.
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/replace/me
